# T Configuration
APP_ENV=development

# Demo mode needs no secrets.
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
MANUAL_LIVE_UNLOCK=false
BINANCE_WITHDRAWALS_SUPPORTED=false
T_DATABASE_URL=sqlite:///data/trading_os.sqlite3
T_AUDIT_LOG_PATH=data/audit/trading_os_audit.jsonl
BINANCE_API_KEY=your_binance_api_key_placeholder
BINANCE_API_SECRET=your_binance_api_secret_placeholder

# Optional 24-hour paper monitoring auto-resume. Public-data paper scanner only.
T_PAPER_SESSION_ENABLED=false
T_PAPER_SESSION_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT
T_PAPER_SESSION_TIMEFRAME=5m
T_PAPER_SESSION_INTERVAL_SECONDS=300
T_PAPER_SESSION_TRADE_NOTIONAL_USDT=50

# Real-world public Binance stream
BINANCE_SYMBOL=btcusdt
Z_SCORE_THRESHOLD=3.0

# Optional Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# TTRL app license admin guard. Leave empty unless running owner/admin backend.
TTRL_ADMIN_TOKEN=
